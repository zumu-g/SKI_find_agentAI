# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# ── Resend (email confirmation for reviews) ───────────────────────────────────
# Free tier: 3,000 emails/month — resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Site URL (used in confirmation email links) ───────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com.au

# ── Apify (for manual sync runs) ─────────────────────────────────────────────
# Get from: apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxx
